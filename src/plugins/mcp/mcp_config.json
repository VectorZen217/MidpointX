{
  "mcpServers": {
    "browser": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "env": {
        "PUPPETEER_LAUNCH_OPTIONS": "{\"userDataDir\": \"./.browser_profile\", \"headless\": false}"
      },
      "description": "Sandboxed Puppeteer browser for web research and scraping. DOES NOT contain user logins or cookies. Use native start commands for identity-bound tasks."
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "./",
        "D:/Reports",
        "D:/",
        "C:/"
      ],
      "env": {}
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {}
    },
    "memory": {
      "name": "Knowledge Graph",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {},
      "source": "library"
    },
    "sqlite": {
      "name": "SQLite",
      "command": "uvx",
      "args": [
        "mcp-server-sqlite",
        "--db-path",
        "./src/workspace/midpointx.db"
      ],
      "env": {},
      "source": "library"
    },
    "brave-search": {
      "name": "Brave Search",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {},
      "source": "library"
    }
  }
}