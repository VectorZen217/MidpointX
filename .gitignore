# MidpointX - Core Ignore Patterns
node_modules/
dist/
build/

# Secrets and Credentials
.env*
!.env.example
*.key
*.pem
apiKey*
api_key*
credentials*.json
*token.json
*creds.json
firebase-adminsdk*.json
google-cloud-key*.json
secrets/

# Logs and Diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Browser Profiles & Cache
.browser_profile*
.puppeteer-data/
.cache/

# Temporary and Visual History
temp/
scratch/
*.tmp
*.temp
*.backup
*.swp
*.swo

# OS Specific
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# MidpointX Private Memory & Job Agent Data
# (Ensuring personal logs and resumes are not shared)
src/workspace/memory/
src/plugins/skills/gemini-autonomous-agent/job_agent/jobs/
travel_workflow_state.json

# Screenshots and Assets in specific skill folders (if any)
**/assets/*.png
**/assets/*.jpg
**/assets/*.pdf
**/references/*.pdf
