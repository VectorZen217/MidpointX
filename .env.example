# Agent Model Selection
ACTIVE_LLM_PROVIDER="anthropic" # 'anthropic', 'openai', 'openrouter', 'google', 'nvidia', 'local'
ACTIVE_MODEL_NAME="INSERT_YOUR_EXPERT_MODEL_NAME"
WORKER_MODEL_NAME="INSERT_YOUR_WORKER_MODEL_NAME"

# API Keys
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""
GEMINI_API_KEY=""
NVIDIA_API_KEY=""

# Server Configuration
PORT=5001
RETRY_COUNT=5

# Messaging Channels
TELEGRAM_BOT_TOKEN=""
DISCORD_BOT_TOKEN=""

# Security Hardening
REQUIRE_APPROVAL_FOR_DESTRUCTIVE=true
# Secret token for authenticating /webhook/* POST requests.
# Must be at least 32 characters. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=""
TOOL_PROFILE="full" # "messaging" | "coding" | "full"

# Sandbox Execution (Docker)
USE_DOCKER_SANDBOX=true
SANDBOX_AUTONOMOUS_MODE=true

# Voice & Vision
ELEVENLABS_API_KEY=""
ENABLE_VOICE=false
ENABLE_SCREENSHOTS=true
ENABLE_PROACTIVE_SCHEDULER=true

# Persistence
PERSISTENCE_ADAPTER="local" # Options: 'local', 'sqlite'
