# Agent Model Selection
ACTIVE_LLM_PROVIDER="google" # 'google', 'anthropic', 'openai', 'openrouter', 'local'
ACTIVE_MODEL_NAME="INSERT_YOUR_EXPERT_MODEL_NAME"
WORKER_MODEL_NAME="INSERT_YOUR_WORKER_MODEL_NAME"

# API Keys
GEMINI_API_KEY="INSERT_YOUR_GEMINI_API_KEY_HERE"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
OPENROUTER_API_KEY=""

# Server Configuration
PORT=8080
RETRY_COUNT=5

# Messaging Channels (Phase 3)
TELEGRAM_BOT_TOKEN=""
DISCORD_BOT_TOKEN=""

# Security Hardening (Phase 4)
REQUIRE_APPROVAL_FOR_DESTRUCTIVE=true
TOOL_PROFILE="full" # "messaging" | "coding" | "full"
USE_DOCKER_SANDBOX=false

# Voice & Vision (Phase 5)
ELEVENLABS_API_KEY="" # Required for High-Quality TTS
ENABLE_VOICE=true # Set to true to receive voice responses back
ENABLE_PROACTIVE_SCHEDULER=true # Set to false to disable all cron-based autonomous missions

# Cloud Native Integration (Phase 6)
GCP_PROJECT_ID=""
GCP_LOCATION="us-central1"
ENABLE_CLOUD_LOGGING=false
PERSISTENCE_ADAPTER="local" # Options: 'local', 'firestore'
